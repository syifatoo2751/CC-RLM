# ── CCR (Claude Code Router) ──────────────────────────────────────────────────
CCR_PORT=8080
CCR_RLM_URL=http://localhost:8081
CCR_VLLM_URL=http://localhost:11434   # Ollama default; change to :8000 for vLLM
CCR_MODEL_OVERRIDE=qwen2.5-coder:7b  # Ollama model name; empty = pass through
CCR_ANTHROPIC_FALLBACK_KEY=sk-ant-your-key-here
CCR_FALLBACK_ENABLED=true

# ── RLM Gateway ───────────────────────────────────────────────────────────────
RLM_PORT=8081
RLM_TOKEN_BUDGET=8000
RLM_WORKER_POOL_SIZE=4
RLM_WALKER_TIMEOUT_MS=500

# ── vLLM ──────────────────────────────────────────────────────────────────────
VLLM_MODEL=MiniMaxAI/MiniMax-M2.5
VLLM_PORT=8000
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=32768
VLLM_HOST=0.0.0.0
